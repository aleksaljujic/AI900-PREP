{
  "name": "ai900-server",
  "version": "1.0.0",
  "type": "commonjs",
  "scripts": {
    "start": "npm install --production && node server.js",
    "build": "echo 'No build needed'",
    "dev": "fuser -k 3001/tcp 2>/dev/null; nodemon server.js",
